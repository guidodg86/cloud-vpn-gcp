/ip ipsec profile
add name=ike2-gcp
/ip ipsec peer
add address={{ peer_ip }}/32 exchange-mode=ike2 name=ike2-gcp profile=ike2-gcp
/ip ipsec proposal
add auth-algorithms=sha512,sha256,sha1 enc-algorithms=aes-256-cbc,aes-256-ctr,aes-256-gcm,aes-192-ctr,aes-192-gcm,aes-128-cbc,aes-128-ctr,aes-128-gcm lifetime=8h name=ike2 pfs-group=none
/ip ipsec identity
add peer=ike2-gcp secret={{ secret }}
/ip ipsec policy
add dst-address=10.25.0.0/16 peer=ike2-gcp proposal=ike2 src-address=192.168.0.0/16 tunnel=yes
